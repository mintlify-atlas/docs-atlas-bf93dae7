  "keyFeatures": [
    "Full-stack e-commerce with React and Express",
    "Integrated Flow payment gateway",
    "Product catalog with categories and reviews",
    "User authentication with JWT and Google OAuth",
    "Admin dashboard for order and product management",
    "Docker and Render deployment support",
    "Performance optimizations with lazy loading and pagination",
    "PostgreSQL database with Supabase storage"
  ],
  "publicApiSurface": [
    "GET /api/productos - List all products",
    "GET /api/productos/:id - Get product details",
    "GET /api/productos/categoria/:categoria - Filter by category",
    "GET /api/categorias - List categories",
    "POST /api/auth/register - User registration",
    "POST /api/auth/login - User login",
    "POST /api/auth/google - Google OAuth login",
    "GET /api/pedidos - List orders",
    "POST /api/pedidos - Create order",
    "POST /api/payments/flow/create - Create Flow payment",
    "GET /api/payments/flow/result - Get payment result",
    "GET /api/reviews/:producto_id - Get product reviews",
    "POST /api/reviews - Create review",
    "GET /api/admin/usuarios - List users (admin)",
    "PUT /api/admin/productos/:id - Update product (admin)",
    "DELETE /api/admin/productos/:id - Delete product (admin)"
  ]
